<Page x:Class="rms_gui.LoginPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RMS - Login" 
        Background="#121212" FontFamily="Segoe UI">

    <Page.Resources>
        <!-- Style for the Toggle Buttons (PIN vs Username) -->
        <Style x:Key="LoginTabButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2A2A30"/>
            <Setter Property="Foreground" Value="#9CA3AF"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#333339"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style for Active Toggle Button -->
        <Style x:Key="ActiveLoginTabButtonStyle" TargetType="Button" BasedOn="{StaticResource LoginTabButtonStyle}">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2563EB"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Style for Numpad Buttons -->
        <Style x:Key="NumpadButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#222228"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#333"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Height" Value="75"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#3B82F6"/>
                                <Setter Property="BorderBrush" Value="#3B82F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style for TextBoxes -->
		<Style x:Key="TextBoxInputStyle" TargetType="TextBox">
			<Setter Property="Background" Value="#222"/>
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="CaretBrush" Value="White"/>
			<Setter Property="BorderBrush" Value="#444"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="FontSize" Value="18"/>
			<Setter Property="Padding" Value="15,0,15,0"/>
			<Setter Property="VerticalContentAlignment" Value="Center"/>

			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="TextBox">
						<Border Background="{TemplateBinding Background}"
								BorderBrush="{TemplateBinding BorderBrush}"
								CornerRadius="8"
								BorderThickness="{TemplateBinding BorderThickness}"
								Padding="{TemplateBinding Padding}">

							<ScrollViewer x:Name="PART_ContentHost"
										  Focusable="False"
										  HorizontalScrollBarVisibility="Hidden"
										  VerticalScrollBarVisibility="Hidden"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsFocused" Value="True">
								<Setter Property="BorderBrush" Value="#3B82F6"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

        <!-- Style for PasswordBoxes -->
        <Style x:Key="PasswordBoxInputStyle" TargetType="PasswordBox">
            <Setter Property="Background" Value="#222"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="8" >
                            <ScrollViewer x:Name="PART_ContentHost" 
                                Padding="{TemplateBinding Padding}"
                                        VerticalAlignment="Center"
                                        />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#3B82F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style for TextBoxes and PasswordBoxes (legacy, kept for compatibility) -->
        <Style x:Key="InputStyle" TargetType="Control">
            <Setter Property="Background" Value="#121212"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Control">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style for the Submit Button -->
        <Style x:Key="SubmitButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#10B981"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#059669"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Left side is bigger (60%) for the image -->
            <ColumnDefinition Width="6*" />
            <!-- Right side (40%) for the login form -->
            <ColumnDefinition Width="4*" />
        </Grid.ColumnDefinitions>

        <!-- LEFT SIDE: Image Placeholder -->
        <Border Grid.Column="0" Background="#1A1A1D" Margin="20" CornerRadius="16" BorderBrush="#333" BorderThickness="1">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="🍽️" FontSize="120" HorizontalAlignment="Center" Foreground="#555"/>
                <TextBlock Text="Restaurant Branding / Image" FontSize="28" FontWeight="Bold" Foreground="#6B7280" Margin="0,20,0,0" HorizontalAlignment="Center"/>
                <TextBlock Text="Will be placed here" FontSize="18" Foreground="#4B5563" Margin="0,10,0,0" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- RIGHT SIDE: Login Form Area -->
        <Grid Grid.Column="1" Background="#121212">

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="320">

                <!-- TOP TOGGLE BUTTONS -->
                <UniformGrid Columns="2" Margin="0,0,0,30">
                    <Button Content="PIN LOGIN" Style="{StaticResource ActiveLoginTabButtonStyle}" Click="LoginTabButton_Click"/>
                    <Button Content="USERNAME" Style="{StaticResource LoginTabButtonStyle}" Click="LoginTabButton_Click"/>
                </UniformGrid>

                <!-- ========================================== -->
                <!-- PIN LOGIN SECTION (Currently Visible)      -->
                <!-- ========================================== -->
                <StackPanel x:Name="PinLoginSection" Visibility="Visible">

                    <!-- PIN Input Display -->
                    <PasswordBox x:Name="PinBox" Style="{StaticResource PasswordBoxInputStyle}" HorizontalContentAlignment="Center" FontSize="36" PasswordChar="●" Margin="0,0,0,25" Height="70" MaxLength="4"/>

                    <!-- Numpad -->
                    <UniformGrid Columns="3" Rows="4">
                        <Button Content="1" Style="{StaticResource NumpadButtonStyle}" Click="NumpadButton_Click"/>
                        <Button Content="2" Style="{StaticResource NumpadButtonStyle}" Click="NumpadButton_Click"/>
                        <Button Content="3" Style="{StaticResource NumpadButtonStyle}" Click="NumpadButton_Click"/>

                        <Button Content="4" Style="{StaticResource NumpadButtonStyle}" Click="NumpadButton_Click"/>
                        <Button Content="5" Style="{StaticResource NumpadButtonStyle}" Click="NumpadButton_Click"/>
                        <Button Content="6" Style="{StaticResource NumpadButtonStyle}" Click="NumpadButton_Click"/>

                        <Button Content="7" Style="{StaticResource NumpadButtonStyle}" Click="NumpadButton_Click"/>
                        <Button Content="8" Style="{StaticResource NumpadButtonStyle}" Click="NumpadButton_Click"/>
                        <Button Content="9" Style="{StaticResource NumpadButtonStyle}" Click="NumpadButton_Click"/>

                        <!-- C (Clear) Button -->
                        <Button Content="C" Style="{StaticResource NumpadButtonStyle}" Foreground="#EF4444" Background="#2A1717" Click="NumpadButton_Click"/>

                        <Button Content="0" Style="{StaticResource NumpadButtonStyle}" Click="NumpadButton_Click"/>

                        <!-- < (Backspace) Button -->
                        <Button Content="&lt;" Style="{StaticResource NumpadButtonStyle}" Foreground="#FBBF24" Background="#2A2417" Click="NumpadButton_Click"/>
                    </UniformGrid>
                </StackPanel>


                <!-- ========================================== -->
                <!-- USERNAME LOGIN SECTION (Currently Hidden)  -->
                <!-- ========================================== -->
                <StackPanel x:Name="UsernameLoginSection" Visibility="Collapsed">

                    <TextBlock Text="Foydalanuvchi nomi (Username)" Foreground="#9CA3AF" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBox x:Name="UsernameBox" Style="{StaticResource TextBoxInputStyle}" Height="60" Margin="0,0,0,20"/>

                    <TextBlock Text="Parol (Password)" Foreground="#9CA3AF" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <PasswordBox x:Name="PasswordBox" Style="{StaticResource PasswordBoxInputStyle}" Height="60" Margin="0,0,0,40"/>

                    <Button Content="Tizimga kirish (Login)" Style="{StaticResource SubmitButtonStyle}" Height="60" Click="UsernameLoginButton_Click"/>

                </StackPanel>

            </StackPanel>
        </Grid>
    </Grid>
</Page>