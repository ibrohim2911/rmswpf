<Page x:Class="rms_gui.ProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RMS - Profile"
        Background="#121212" FontFamily="Segoe UI">

    <Page.Resources>
        <!-- Style for Bottom Navigation Buttons -->
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#9CA3AF"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2A2A2E"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style for Input Fields (PasswordBox) -->
        <Style x:Key="InputStyle" TargetType="Control">
            <Setter Property="Background" Value="#121212"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Control">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style for Primary Actions (Save Button) -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2563EB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style for Statistic Cards -->
        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#1E1E24"/>
            <Setter Property="BorderBrush" Value="#333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="10"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="70" />
            <!-- Bottom Bar Area -->
        </Grid.RowDefinitions>

        <!-- MAIN CONTENT AREA -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <!-- Left: User Info & Password -->
                <ColumnDefinition Width="2*" />
                <!-- Right: Dashboard / Statistics -->
            </Grid.ColumnDefinitions>

            <!-- LEFT PANEL: USER INFO & SETTINGS -->
            <Grid Grid.Column="0" Background="#1A1A1D">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="30">

                        <!-- User Profile Header -->
                        <Border Background="#1E1E24" BorderBrush="#333" BorderThickness="1" CornerRadius="16" Padding="20" Margin="0,0,0,30">
                            <StackPanel HorizontalAlignment="Center">
                                <!-- Avatar -->
                                <Border Width="100" Height="100" Background="#2A2A30" CornerRadius="50" Margin="0,0,0,15">
                                    <TextBlock Text="👤" FontSize="50" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#555"/>
                                </Border>
                                <TextBlock Text="John Doe" Foreground="White" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <Border Background="#3B82F6" CornerRadius="6" Padding="10,4" Margin="0,10,0,0" HorizontalAlignment="Center">
                                    <TextBlock Text="MENEJER (MANAGER)" Foreground="White" FontSize="14" FontWeight="Bold"/>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Change Password Section -->
                        <TextBlock Text="Parolni o'zgartirish (Change Password)" Foreground="White" FontWeight="Bold" FontSize="18" Margin="0,0,0,20"/>

                        <TextBlock Text="Joriy parol (Current Password)" Foreground="#9CA3AF" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <PasswordBox Style="{StaticResource InputStyle}" PasswordChar="●" Margin="0,0,0,20"/>

                        <TextBlock Text="Yangi parol (New Password)" Foreground="#9CA3AF" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <PasswordBox Style="{StaticResource InputStyle}" PasswordChar="●" Margin="0,0,0,20"/>

                        <TextBlock Text="Yangi parolni tasdiqlang (Confirm)" Foreground="#9CA3AF" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <PasswordBox Style="{StaticResource InputStyle}" PasswordChar="●" Margin="0,0,0,30"/>

                        <Button Content="Saqlash (Save Changes)" Style="{StaticResource PrimaryButtonStyle}"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- DIVIDER (Visual) -->
            <Border Grid.Column="0" HorizontalAlignment="Right" Width="1" Background="#333"/>

            <!-- RIGHT PANEL: STATISTICS DASHBOARD -->
            <Grid Grid.Column="1" Background="#121212">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="30,30,30,10">
                    <TextBlock Text="Bugungi Statistika (Today's Statistics)" Foreground="White" FontSize="26" FontWeight="Bold"/>
                    <TextBlock Text="Ma'lumotlar real vaqt rejimida yangilanadi" Foreground="#9CA3AF" FontSize="14" Margin="0,5,0,0"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" Margin="20,0,20,20" VerticalScrollBarVisibility="Auto">

                    <!-- 
                        NOTE FOR C# CODE-BEHIND:
                        You can set x:Name to these cards and toggle Visibility based on user role.
                        e.g. Waiter -> show Tables Served, Tips.
                        Cashier -> show Cash in Register, Transactions.
                        Manager -> show Total Sales, Average Receipt.
                    -->
                    <WrapPanel Orientation="Horizontal">

                        <!-- CARD 1: Total Sales (Visible for Admin/Cashier) -->
                        <Border Style="{StaticResource StatCardStyle}" Width="260" Height="150">
                            <StackPanel>
                                <Grid>
                                    <TextBlock Text="Jami Savdo (Total Sales)" Foreground="#9CA3AF" FontSize="14" FontWeight="SemiBold"/>
                                    <TextBlock Text="💰" HorizontalAlignment="Right" FontSize="20"/>
                                </Grid>
                                <TextBlock Text="4,250,000 so'm" Foreground="#10B981" FontSize="26" FontWeight="Bold" Margin="0,20,0,10"/>
                                <TextBlock Text="+12% kechagiga nisbatan" Foreground="#34D399" FontSize="12"/>
                            </StackPanel>
                        </Border>

                        <!-- CARD 2: Active Orders (Visible for All) -->
                        <Border Style="{StaticResource StatCardStyle}" Width="260" Height="150">
                            <StackPanel>
                                <Grid>
                                    <TextBlock Text="Aktiv Buyurtmalar (Active)" Foreground="#9CA3AF" FontSize="14" FontWeight="SemiBold"/>
                                    <TextBlock Text="📋" HorizontalAlignment="Right" FontSize="20"/>
                                </Grid>
                                <TextBlock Text="12 ta" Foreground="White" FontSize="28" FontWeight="Bold" Margin="0,20,0,10"/>
                                <TextBlock Text="3 ta buyurtma tayyor" Foreground="#FBBF24" FontSize="12"/>
                            </StackPanel>
                        </Border>

                        <!-- CARD 3: Tables Served (Visible for Waiter/Admin) -->
                        <Border Style="{StaticResource StatCardStyle}" Width="260" Height="150">
                            <StackPanel>
                                <Grid>
                                    <TextBlock Text="Xizmat ko'rsatilgan (Tables)" Foreground="#9CA3AF" FontSize="14" FontWeight="SemiBold"/>
                                    <TextBlock Text="🍽️" HorizontalAlignment="Right" FontSize="20"/>
                                </Grid>
                                <TextBlock Text="24 ta stol" Foreground="White" FontSize="28" FontWeight="Bold" Margin="0,20,0,10"/>
                                <TextBlock Text="O'rtacha vaqt: 45 min" Foreground="#9CA3AF" FontSize="12"/>
                            </StackPanel>
                        </Border>

                        <!-- CARD 4: Average Receipt (Visible for Admin) -->
                        <Border Style="{StaticResource StatCardStyle}" Width="260" Height="150">
                            <StackPanel>
                                <Grid>
                                    <TextBlock Text="O'rtacha Chek (Avg Receipt)" Foreground="#9CA3AF" FontSize="14" FontWeight="SemiBold"/>
                                    <TextBlock Text="🧾" HorizontalAlignment="Right" FontSize="20"/>
                                </Grid>
                                <TextBlock Text="175,000 so'm" Foreground="#3B82F6" FontSize="26" FontWeight="Bold" Margin="0,20,0,10"/>
                                <TextBlock Text="Barqaror holatda" Foreground="#9CA3AF" FontSize="12"/>
                            </StackPanel>
                        </Border>

                        <!-- CARD 5: Cash in Register (Visible for Cashier/Admin) -->
                        <Border Style="{StaticResource StatCardStyle}" Width="260" Height="150">
                            <StackPanel>
                                <Grid>
                                    <TextBlock Text="Kassadagi Naqd (Cash)" Foreground="#9CA3AF" FontSize="14" FontWeight="SemiBold"/>
                                    <TextBlock Text="💵" HorizontalAlignment="Right" FontSize="20"/>
                                </Grid>
                                <TextBlock Text="1,850,000 so'm" Foreground="White" FontSize="26" FontWeight="Bold" Margin="0,20,0,10"/>
                                <TextBlock Text="Oxirgi inkassatsiya: 14:00" Foreground="#9CA3AF" FontSize="12"/>
                            </StackPanel>
                        </Border>

                    </WrapPanel>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- BOTTOM BAR: NAVIGATION -->
        <Border Grid.Row="1" Background="#1A1A1D" BorderBrush="#333" BorderThickness="0,1,0,0">
            <UniformGrid Columns="5" Margin="5">
                <Button Style="{StaticResource NavButtonStyle}" Content="📋 Orders" />
                <Button Style="{StaticResource NavButtonStyle}" Content="➕ Create Order" />
                <Button Style="{StaticResource NavButtonStyle}" Content="↩️ Back" />

                <!-- ACTIVE TAB: Profile -->
                <Button Style="{StaticResource NavButtonStyle}" Content="👤 Profile" Foreground="White" Background="#3B82F6" />

                <Button Style="{StaticResource NavButtonStyle}" Content="🚪 Log out" Foreground="#F87171"/>
            </UniformGrid>
        </Border>
    </Grid>
</Page>